# Templated by Ansible registries_mirror role (airgap 전용).
# containerd 레벨에서 공개 레지스트리를 내부 레지스트리로 리라이트한다.
# 이렇게 하면 helm-values의 이미지 주소를 일일이 바꾸지 않아도
# 폐쇄망에서 내부 레지스트리로부터 이미지를 당긴다.
#
# 전제: image_registry({{ image_registry }})에 아래 경로가 사전 미러되어 있어야 한다.
#   docker.io/*, quay.io/*, registry.k8s.io/*, ghcr.io/*
# (docs/adr/0005-airgap-strategy.md 참조)
mirrors:
  docker.io:
    endpoint:
      - "https://{{ image_registry }}"
  quay.io:
    endpoint:
      - "https://{{ image_registry }}"
  registry.k8s.io:
    endpoint:
      - "https://{{ image_registry }}"
  ghcr.io:
    endpoint:
      - "https://{{ image_registry }}"

configs:
  "{{ image_registry }}":
    tls:
      # 내부 레지스트리가 사설 CA/self-signed면 false 또는 ca_file 지정
      insecure_skip_verify: true
